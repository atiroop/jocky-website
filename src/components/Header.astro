---
import { SITE_TITLE } from '../consts';
import { cdnUrl } from '../lib/cdn';
import HeaderLink from './HeaderLink.astro';

const brandLogoUrl = cdnUrl('brand/logo.png');
---

<header>
	<nav>
		<h2>
			<a class="brand" href="/">
				<img src={brandLogoUrl} alt="" width="72" height="72" />
				<span>{SITE_TITLE}</span>
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">หน้าแรก</HeaderLink>
			<HeaderLink href="/blog">บทความ</HeaderLink>
			<HeaderLink href="/about">เกี่ยวกับ</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1rem;
		background: rgba(17, 16, 14, 88%);
		border-bottom: 1px solid var(--line);
		backdrop-filter: blur(14px);
	}

	h2 {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 600;
		letter-spacing: 0;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		color: var(--text);
		white-space: nowrap;
	}

	.brand img {
		flex: 0 0 auto;
		width: 46px;
		height: 32px;
		object-fit: contain;
		border-radius: 0;
		filter: drop-shadow(0 0 12px rgba(54, 207, 192, 18%));
	}

	.brand span {
		line-height: 1;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: var(--wide-width);
		max-width: 100%;
		min-height: 68px;
		margin: 0 auto;
		gap: 1rem;
	}

	nav a {
		padding: 0.8rem 0.25rem;
		color: var(--muted);
		border-bottom: 1px solid transparent;
		text-decoration: none;
	}

	nav a:hover {
		color: var(--text);
	}

	nav a.active {
		color: var(--text);
		border-bottom-color: var(--accent);
	}

	.internal-links {
		display: flex;
		gap: 1rem;
	}

	@media (max-width: 720px) {
		header {
			padding: 0 0.75rem;
		}

		nav {
			min-height: 64px;
			align-items: flex-start;
			flex-direction: column;
			justify-content: center;
			gap: 0.1rem;
		}

		.internal-links {
			gap: 0.85rem;
			font-size: 0.9rem;
		}

		nav a {
			padding: 0.25rem 0;
		}
	}
</style>
