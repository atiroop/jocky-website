---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} สมุดบันทึกส่วนตัว</p>
	<p>เขียนช้า ๆ เก็บไว้ให้อ่านซ้ำในวันที่ต้องการความเงียบ</p>
</footer>
<style>
	footer {
		width: var(--content-width);
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 3rem 0 5rem;
		border-top: 1px solid var(--line);
		color: var(--subtle);
		font-size: 0.9rem;
		line-height: 1.7;
	}

	footer p {
		margin: 0;
	}

	footer p + p {
		margin-top: 0.35rem;
	}
</style>
