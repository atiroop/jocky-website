---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="th">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				padding-top: 5rem;
			}

			.intro {
				max-width: 42rem;
			}

			.kicker {
				margin: 0 0 1rem;
				color: var(--subtle);
				font-size: 0.9rem;
			}

			.intro h1 {
				margin-bottom: 1.25rem;
			}

			.intro p {
				color: var(--muted);
			}

			.note-links {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8rem;
				margin-top: 2.25rem;
			}

			.note-links a {
				display: inline-flex;
				align-items: center;
				min-height: 2.6rem;
				padding: 0.35rem 0;
				color: var(--text);
				text-decoration: none;
				border-bottom: 1px solid var(--accent);
			}

			.note-links a:hover {
				color: var(--accent-soft);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p class="kicker">Personal blog / articles / diary / digital notebook</p>
				<h1>พื้นที่เงียบ ๆ สำหรับบันทึกสิ่งที่คิด อ่าน และพบเจอ</h1>
				<p>
					ที่นี่เป็นสมุดบันทึกส่วนตัวสำหรับบทความสั้น บันทึกประจำวัน ความคิดระหว่างทาง
					และรายละเอียดเล็ก ๆ ที่ยังไม่อยากปล่อยให้หายไปกับหน้าจอ.
				</p>
				<p>
					ไม่มีแดชบอร์ด ไม่มีความเร่งรีบ มีแค่ตัวอักษร พื้นที่ว่าง และจังหวะการอ่านที่ค่อย ๆ
					พาเรื่องหนึ่งไปสู่อีกเรื่องหนึ่ง.
				</p>
				<div class="note-links">
					<a href="/blog">อ่านบทความล่าสุด</a>
					<a href="/about">รู้จักพื้นที่นี้</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
