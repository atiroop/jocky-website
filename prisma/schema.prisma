generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  posts        Post[]
  apdPrescriptions APDPrescription[]
  apdDailyLogs     APDDailyLog[]
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  posts       Post[]
}

model Post {
  id          Int        @id @default(autoincrement())
  title       String
  slug        String     @unique
  excerpt     String?    @db.Text
  content     String     @db.LongText
  coverImage  String?
  status      PostStatus @default(DRAFT)
  seoTitle    String?
  seoDesc     String?    @db.Text
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  authorId    Int
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categoryId  Int?
  category    Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
}

model APDPrescription {
  id                 Int      @id @default(autoincrement())
  name               String   @default("Default prescription profile")
  solutionBag1       String
  solutionBag2       String
  totalVolumeMl      Int
  therapyTimeMinutes Int
  fillVolumeMl       Int
  cycles             Int
  dwellTimeMinutes   Int
  lastFillMl         Int?     @default(0)
  manualExchange     String?
  isDefaultProfile   Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId             Int
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyLogs          APDDailyLog[]

  @@index([userId])
  @@index([isDefaultProfile])
}

model APDDailyLog {
  id                 Int      @id @default(autoincrement())
  date               DateTime @db.Date
  treatmentStartTime String
  weightKg           Decimal  @db.Decimal(5, 2)
  systolicBp         Int
  diastolicBp        Int
  pulse              Int
  bloodGlucoseMgDl   Int?
  iDrainVolumeMl     Int
  totalUfMl          Int
  urineAvgDayMl      Int
  drainageAppearance String?
  remark             String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId             Int
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptionId     Int?
  prescription       APDPrescription? @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([prescriptionId])
}

enum Role {
  ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  PUBLISHED
}
